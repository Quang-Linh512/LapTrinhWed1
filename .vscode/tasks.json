{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: compile studentmanager",
            "type": "shell",
            "command": ".\\mvnw.cmd",
            "args": ["clean", "compile"],
            "options": { "cwd": "${workspaceFolder}/studentmanager" },
            "group": "build",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "Spring Boot: Run studentmanager",
            "type": "shell",
            "command": ".\\mvnw.cmd",
            "args": ["spring-boot:run"],
            "options": { "cwd": "${workspaceFolder}/studentmanager" },
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "new" }
        }
    ]
}
